{
  "name": "onda-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.1",
    "@supabase/supabase-js": "^2.45.4",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.4",
    "firebase-admin": "^12.7.0",
    "hono": "^4.6.13",
    "jose": "^5.9.6",
    "pdfkit": "^0.15.1",
    "pg": "^8.13.1",
    "pg-boss": "^10.1.6",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "ulid": "^2.3.0",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pdfkit": "^0.13.5",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
