# ---- Runtime ----
NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# ---- Database ----
DATABASE_URL=postgres://postgres:postgres@localhost:5432/onda

# ---- Auth (Firebase) ----
# Firebase Auth is the sole identity provider (Google / Apple / Email-Password).
# Both vars are required — the server exits at boot if either is missing.
# Get them from Firebase Console → Project Settings → Service Accounts → Generate new private key.
FIREBASE_PROJECT_ID=
# The full JSON of the service-account key, on one line.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ---- SMS (Hubtel / Arkesel) ----
SMS_PROVIDER=hubtel
SMS_SENDER_ID=ONDA
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
ARKESEL_API_KEY=

# ---- Push (Expo) ----
EXPO_PUSH_ACCESS_TOKEN=

# ---- Storage (Cloudflare R2) ----
# Account ID from Cloudflare Dash → R2 → Overview (right sidebar)
R2_ACCOUNT_ID=
# S3-compatible credentials from Cloudflare Dash → R2 → Manage R2 API Tokens
# Scope token to Object Read & Write on the two buckets below.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_IMAGES=onda-images
R2_BUCKET_PDFS=onda-pdfs
# Leave empty to serve everything via signed URLs (recommended — both buckets contain private data)
R2_PUBLIC_BASE_URL=

# ---- Business rules ----
CASH_CONFIRMATION_WINDOW_HOURS=48
REMINDER_COOLDOWN_HOURS=24
