# ---- Runtime ----
NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# ---- Database ----
DATABASE_URL=postgres://postgres:postgres@localhost:5432/onda

# ---- Auth ----
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# OTP
OTP_TTL_SECONDS=300
OTP_RATE_LIMIT_PER_MINUTE=1
OTP_RATE_LIMIT_PER_HOUR=5
# Set to "true" to log OTP codes to stdout instead of sending SMS (dev only)
OTP_DEV_LOG_ONLY=true

# ---- SMS (Hubtel / Arkesel) ----
SMS_PROVIDER=hubtel
SMS_SENDER_ID=ONDA
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
ARKESEL_API_KEY=

# ---- Push (Expo) ----
EXPO_PUSH_ACCESS_TOKEN=

# ---- Storage (Cloudflare R2) ----
# Account ID from Cloudflare Dash → R2 → Overview (right sidebar)
R2_ACCOUNT_ID=
# S3-compatible credentials from Cloudflare Dash → R2 → Manage R2 API Tokens
# Scope token to Object Read & Write on the two buckets below.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_IMAGES=onda-images
R2_BUCKET_PDFS=onda-pdfs
# Leave empty to serve everything via signed URLs (recommended — both buckets contain private data)
R2_PUBLIC_BASE_URL=

# ---- Business rules ----
CASH_CONFIRMATION_WINDOW_HOURS=48
REMINDER_COOLDOWN_HOURS=24
